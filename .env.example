# ===========================================
# NutriLens Environment Variables
# ===========================================
# Copy this file to .env.local and fill in your values

# ===========================================
# Database - Supabase
# ===========================================
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ===========================================
# Authentication - NextAuth
# ===========================================
NEXTAUTH_URL=https://nutrilens-ai-food-analyzer.vercel.app
NEXTAUTH_SECRET=your_nextauth_secret_key

# ===========================================
# Google OAuth
# ===========================================
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ===========================================
# AI/ML Services
# ===========================================
OPENAI_API_KEY=your_openai_api_key
GOOGLE_VISION_API_KEY=your_google_vision_api_key

# ===========================================
# Barcode API
# ===========================================
BARCODE_LOOKUP_API_KEY=your_barcode_api_key

# ===========================================
# App Configuration
# ===========================================
NEXT_PUBLIC_APP_URL=https://nutrilens-ai-food-analyzer.vercel.app
NEXT_PUBLIC_APP_NAME=NutriLens
